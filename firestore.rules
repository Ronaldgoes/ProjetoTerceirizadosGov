rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isConfiguredAdminEmail() {
      return isSignedIn() && request.auth.token.email == "rgoes@sef.sc.gov.br";
    }

    function isAdmin() {
      return isConfiguredAdminEmail()
        || (
          isSignedIn()
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
        );
    }

    function validRole(role) {
      return role in ["user", "admin"];
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid)
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.name is string
        && request.resource.data.email is string
        && validRole(request.resource.data.role)
        && (
          request.resource.data.role == "user"
          || (request.resource.data.role == "admin" && isConfiguredAdminEmail())
        );

      allow update: if
        (isOwner(uid)
          && request.resource.data.email == resource.data.email
          && request.resource.data.role == resource.data.role)
        || isAdmin();

      allow delete: if false;

      match /monitors/{docId} {
        allow read, write: if isOwner(uid) || isAdmin();
      }

      match /alerts/{docId} {
        allow read, write: if isOwner(uid) || isAdmin();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
